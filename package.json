{
  "name": "sd003-framework",
  "version": "1.0.0",
  "description": "SD003 Framework - Spec-Driven Development with GAS Local Testing Integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "sd003": "./bin/sd003.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "sync:codex-prompts": "node scripts/sync-codex-prompts.js",
    "sync:gemini": "node scripts/sync-gemini-features.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:gas-fakes": "jest --testPathPattern=tests/gas-fakes/ --setupFiles=./tests/gas-fakes/setup.ts",
    "test:e2e": "playwright test",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist coverage .nyc_output",
    "prepublish": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "dev:server": "ts-node src/dev-server/index.ts",
    "gas:init": "node dist/scripts/gas-init.js",
    "gas:test": "npm run build && npm test",
    "gas:deploy": "node dist/scripts/gas-deploy.js",
    "spec:sync": "node dist/spec-driven/sync.js",
    "spec:validate": "node dist/spec-driven/validate.js",
    "qa:test": "npm run build && npm test && npm run test:e2e",
    "qa:deploy:safe": "npm run qa:test && node dist/scripts/deploy-guard.js",
    "test:validate-data": "powershell -ExecutionPolicy Bypass -File scripts/validate-test-data.ps1",
    "e2e:setup": "powershell -ExecutionPolicy Bypass -File .claude/skills/gas-e2e/scripts/setup-e2e.ps1"
  },
  "keywords": [
    "spec-driven-development",
    "gas",
    "google-apps-script",
    "testing",
    "mock",
    "framework",
    "local-development",
    "requirements-traceability",
    "id-registry",
    "claude-integration"
  ],
  "author": "SD003 Team",
  "license": "MIT",
  "dependencies": {
"@google/clasp": "^2.5.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@playwright/test": "^1.46.0",
    "@types/express": "^4.17.23",
    "@types/google-apps-script": "^1.0.83",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^11.1.0",
    "express": "^4.21.2",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.3",
    "globby": "^14.0.1",
    "js-yaml": "^4.1.1",
    "sqlite3": "^5.1.7",
    "ts-morph": "^22.0.0",
    "ts-node": "^10.9.2",
    "zx": "^8.1.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "c8": "^8.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.2",
    "@mcpher/gas-fakes": "^1.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "scripts/",
    "templates/",
    ".claude/",
    ".gemini/",
    ".handoff/",
    ".sd/settings/",
    ".sessions/session-template.md",
    ".sd/ai-coordination/workflow/",
    ".sd/ralph/",
    ".sd/steering/",
    ".antigravity/",
    "docs/",
    "AGENTS.md"
  ]
}
