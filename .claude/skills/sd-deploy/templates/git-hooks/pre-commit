#!/bin/bash
# pre-commit hook: .sd/ の変更を自動ステージ
#
# 目的: .sd/ ファイルが modified 状態のままcommitされることを防ぐ。
# ただし .sd/ がディスク上に存在しない場合はスキップ（削除を防ぐ）。
#
# 背景: 2026-03-28 Bug Trace で確定。
# Refs: anthropics/claude-code#34330

# .sd/ がディスク上に存在しない場合はスキップ
if [ ! -d ".sd" ]; then
    exit 0
fi

# modified（変更あり、ディスク上に存在する）ファイルのみステージ
sd_modified=$(git diff --name-only .sd/ 2>/dev/null | wc -l)
sd_untracked=$(git ls-files --others --exclude-standard .sd/ 2>/dev/null | wc -l)
total=$((sd_modified + sd_untracked))

if [ "$total" -gt 0 ]; then
    # modified ファイルをステージ（存在するもののみ）
    git diff --name-only .sd/ 2>/dev/null | while read f; do
        [ -f "$f" ] && git add "$f"
    done
    # untracked ファイルをステージ
    git ls-files --others --exclude-standard .sd/ 2>/dev/null | while read f; do
        [ -f "$f" ] && git add "$f"
    done
    echo "[pre-commit] auto-staged $total .sd/ file(s)"
fi

exit 0
