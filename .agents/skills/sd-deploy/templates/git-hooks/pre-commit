#!/bin/bash
# pre-commit hook: .sd/ の変更を自動ステージ（-f 強制）+ スナップショット採取
#
# 目的: .sd/ ファイルが modified 状態のままcommitされることを防ぐ。
# .sd/ は .gitignore に含まれるため、git add -f が必須。
#
# 背景: 2026-03-28 Bug Trace で確定。2026-04-04 gitignore起因の再発で -f 追加。
# 2026-06-10 スナップショット採取を追加（post-commit の partial wipe 検知・復元の正本）。
# 2026-07-05 B11/B14 修正: スナップショット採取をアトミック化（一時ディレクトリ→リネーム
# スワップ）し、コピー失敗時は旧スナップショットを保持する。日本語等の非ASCIIパスが
# 正しく扱われるよう core.quotepath=false + NUL区切りに変更。
# また post-commit の鮮度判定用に、採取時点の親コミットhash(この後作られるコミットの
# 親になるHEAD)を sd-snapshot.meta に記録する（B12対応）。
# Refs: anthropics/claude-code#34330

# .sd/ がディスク上に存在しない場合はスキップ
if [ ! -d ".sd" ]; then
    exit 0
fi

# git管理下の .sd/ ファイルがディスク上で変更されているか確認
# .gitignore対象のため --no-index で比較
# 非ASCIIファイル名がクォートされて壊れないよう quotepath=false + NUL区切り
while IFS= read -r -d '' f; do
    if [ -f "$f" ]; then
        # ファイルが存在し、HEADと差分があればステージ
        if ! git -c core.quotepath=false diff --quiet HEAD -- "$f" 2>/dev/null; then
            git add -f -- "$f"
            echo "[pre-commit] auto-staged (modified): $f"
        fi
    fi
done < <(git -c core.quotepath=false ls-tree -z -r HEAD --name-only 2>/dev/null | grep -z "^\.sd/")

# ディスク上に存在するが git 未追跡の .sd/ ファイルもステージ
# --exclude-standard は使わない（.gitignore対象を検出するため）
while IFS= read -r -d '' f; do
    if ! git ls-files --error-unmatch -- "$f" >/dev/null 2>&1; then
        git add -f -- "$f"
        echo "[pre-commit] auto-staged (new): $f"
    fi
done < <(find .sd/ -type f -print0 2>/dev/null)

# === .sd/ スナップショット採取（L4強化: post-commit復元の正本） ===
# ランタイムの working tree refresh は .git/ 内部を触らないため、
# commit直後に .sd/ が消されてもスナップショットは生き残る。
# post-commit はこれを正としてファイル単位で欠損を検知・復元する
# （HEADに無い=未commit相当のファイルも、commit時点でディスクにあれば守られる）。
#
# B11対応: 旧実装は `rm -rf sd-snapshot` してから `cp -r` していたため、
# コピーがwipe/失敗で中断すると唯一の正本が消える。
# → 一時ディレクトリにコピーしてから、完了後にのみ swap する（旧スナップショットは
#   コピー完了までそのまま残る）。
GIT_DIR_PATH=$(git rev-parse --git-dir 2>/dev/null)
if [ -n "$GIT_DIR_PATH" ]; then
    SNAPSHOT="$GIT_DIR_PATH/sd-snapshot"
    TMP_SNAPSHOT="$GIT_DIR_PATH/sd-snapshot.tmp.$$"
    TMP_META="$GIT_DIR_PATH/sd-snapshot.meta.tmp.$$"
    rm -rf "$TMP_SNAPSHOT"
    rm -f "$TMP_META"

    if cp -r .sd "$TMP_SNAPSHOT" 2>/dev/null; then
        # B12対応: この後作られるコミットの「親」になる現在のHEADを記録する。
        # 初回コミット（HEADがまだ無い）は "ROOT" を使う。
        PARENT_HASH=$(git rev-parse --verify -q HEAD 2>/dev/null || echo "ROOT")
        printf '%s\n' "$PARENT_HASH" > "$TMP_META"

        # アトミックスワップ: 旧スナップショットを退避 → 新を配置 → 旧を削除。
        # cp が完了した後のこの区間は単純なディレクトリ/ファイルrenameのみなので、
        # 旧スナップショットが「存在しない」瞬間は極小化される。
        OLD_ASIDE=""
        if [ -d "$SNAPSHOT" ]; then
            OLD_ASIDE="$GIT_DIR_PATH/sd-snapshot.old.$$"
            mv "$SNAPSHOT" "$OLD_ASIDE"
        fi
        mv "$TMP_SNAPSHOT" "$SNAPSHOT"
        mv -f "$TMP_META" "$GIT_DIR_PATH/sd-snapshot.meta"
        [ -n "$OLD_ASIDE" ] && rm -rf "$OLD_ASIDE"
    else
        # コピー失敗（中断含む）: 旧スナップショットに一切触れず、一時物のみ掃除。
        echo "[pre-commit] WARNING: .sd/ snapshot copy failed. Keeping previous snapshot (if any)." >&2
        rm -rf "$TMP_SNAPSHOT"
        rm -f "$TMP_META"
    fi
fi

exit 0
