#!/bin/bash
# post-commit hook: .sd/ 消失検知 + 自動復元 + async push + Google Drive backup
#
# 背景: 2026-03-28 Bug Trace で確定。2026-04-04 再発。
# commit直後にランタイムが .sd/ を消すことがあるため、post-commitで検知して即復元する。
# Refs: anthropics/claude-code#34330

# === .sd/ 消失検知 + 自動復元 ===
# HEADに .sd/ ファイルが存在するか確認
SD_IN_HEAD=$(git ls-tree -r HEAD --name-only 2>/dev/null | grep "^\.sd/" | head -1)

if [ -n "$SD_IN_HEAD" ] && [ ! -d ".sd" ]; then
    # HEADにあるのにディスクにない = 消失
    echo "[post-commit] WARNING: .sd/ disappeared after commit. Auto-restoring..."
    git ls-tree -r HEAD --name-only | grep "^\.sd/" | while read f; do
        mkdir -p "$(dirname "$f")"
        git show "HEAD:$f" > "$f"
    done
    echo "[post-commit] .sd/ restored from HEAD ($(git ls-tree -r HEAD --name-only | grep -c '^\.sd/') files)"
fi

# === async push ===
BRANCH=$(git rev-parse --abbrev-ref HEAD)
[ "$BRANCH" = "HEAD" ] && exit 0
git remote get-url origin >/dev/null 2>&1 || exit 0

nohup git push origin "$BRANCH" > /dev/null 2>&1 &

# === Google Drive backup ===
GDRIVE_BACKUP="G:/マイドライブ/sd-backup"
PROJECT_NAME=$(basename "$(pwd)")
if [ -d "$GDRIVE_BACKUP" ] && [ -d ".sd" ]; then
    nohup cp -r .sd/ "$GDRIVE_BACKUP/$PROJECT_NAME/" > /dev/null 2>&1 &
fi

exit 0
